# Application Configuration
APP_NAME="Diksha Accounting ERP"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Riyadh

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=diksha_erp
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail Configuration
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=info@diksha.com
MAIL_FROM_NAME="Diksha Accounting"

# File Upload
UPLOAD_MAX_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx,xls,xlsx

# ZATCA Configuration (Saudi Arabia)
ZATCA_ENABLED=true
ZATCA_API_URL=https://zatca.gov.sa/api
ZATCA_API_KEY=
ZATCA_CERTIFICATE_PATH=

# QR Code
QR_CODE_ENABLED=true

# Arabic Support
ARABIC_SUPPORT_ENABLED=true
DEFAULT_LANGUAGE=ar
ALLOWED_LANGUAGES=ar,en
