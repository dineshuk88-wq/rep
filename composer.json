{
  "name": "diksha/accounting-erp",
  "description": "Diksha Accounting ERP - Saudi Edition",
  "type": "project",
  "require": {
    "php": "^8.2",
    "ext-pdo": "*",
    "ext-json": "*",
    "ext-curl": "*",
    "ext-gd": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\": "database/",
      "Tests\\": "tests/"
    },
    "files": [
      "app/helpers.php"
    ]
  },
  "scripts": {
    "migrate": "php migrate.php",
    "seed": "php seed.php",
    "test": "phpunit",
    "lint": "phpcs"
  }
}
